# Optional override. Use your current Wi-Fi IPv4 address when testing on Expo Go.
# Example: EXPO_PUBLIC_API_URL=http://10.213.234.180:5000/api
# Leave unset to let the frontend auto-detect the Expo/web host and call port 5000.
# EXPO_PUBLIC_API_URL=http://YOUR_WIFI_IPV4:5000/api

EXPO_PUBLIC_API_PORT=5000
EXPO_PUBLIC_API_PATH=/api
