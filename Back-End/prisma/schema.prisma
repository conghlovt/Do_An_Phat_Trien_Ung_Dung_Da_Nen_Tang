generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  admin
  partner
  customer
  staff
  SUPER_ADMIN
  OPERATOR
  ACCOUNTANT
}

enum UserStatus {
  ACTIVE
  PENDING
  BLOCKED
  active
  inactive
  banned
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PropertyStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum VoucherStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum PropertyType {
  hotel
  homestay
  resort
  motel
  apartment
}

enum HotelStatus {
  draft
  pending
  approved
  rejected
  suspended
}

enum CancellationPolicy {
  flexible
  moderate
  strict
  non_refundable
}

enum RoomTypeStatus {
  active
  inactive
}

enum RoomUnitStatus {
  available
  occupied
  maintenance
  cleaning
}

enum BookingType {
  hourly
  overnight
  daily
}

enum MediaType {
  image
  video
}

enum AmenityCategory {
  general
  room
  bathroom
  entertainment
  safety
  service
}

// ============================================================
// MERGED USER MODEL
// ============================================================

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  password      String
  username      String
  phone         String?     @unique
  role          Role        @default(customer)
  code          String?
  avatar        String?
  refreshToken  String?
  status        UserStatus  @default(active)
  emailVerified Boolean     @default(false) @map("email_verified")
  lastLoginAt   DateTime?   @map("last_login_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations (Schema 1)
  properties Property[]
  bookings   Booking[]
  reviews    Review[]
  contents   ContentPost[]

  // Relations (Schema 2)
  ownedHotels    Hotel[]      @relation("HotelOwner")
  approvedHotels Hotel[]      @relation("HotelApprover")
  uploadedFiles  FileObject[]
  hotelImages    HotelImage[]
  hotelVideos    HotelVideo[]
  roomMedia      RoomMedia[]

  @@index([role, status])
  @@map("users")
}

// ============================================================
// MODELS FROM SCHEMA 1
// ============================================================

model Property {
  id          String         @id @default(uuid())
  name        String
  description String?
  address     String
  city        String
  type        String
  images      String[]
  amenities   String[]
  status      PropertyStatus @default(PENDING)
  ownerId     String
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms       Room[]
  bookings    Booking[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Room {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  type       String
  price      Float
  capacity   Int
  totalRooms Int      @default(1)
  available  Int      @default(1)
  bookings   Booking[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Booking {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId  String
  property    Property      @relation(fields: [propertyId], references: [id])
  roomId      String
  room        Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  checkIn     DateTime
  checkOut    DateTime
  guests      Int           @default(1)
  totalPrice  Float
  voucherCode String?
  status      BookingStatus @default(PENDING)
  paymentId   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  reviews     Review[]
}

model Review {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId String
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  images    String[]
  reply     String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Voucher {
  id         String        @id @default(uuid())
  code       String        @unique
  discount   Float
  type       String
  expiry     DateTime
  usageLimit Int           @default(100)
  usedCount  Int           @default(0)
  status     VoucherStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Finance {
  id           String   @id @default(uuid())
  month        String
  totalRevenue Float
  platformFee  Float
  partnerNet   Float
  status       String
  createdAt    DateTime @default(now())
}

model ContentPost {
  id        String        @id @default(uuid())
  title     String
  category  String
  thumbnail String?
  excerpt   String?
  body      String        @db.Text
  views     Int           @default(0)
  status    ContentStatus @default(DRAFT)
  authorId  String?
  author    User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model RolePermission {
  id          String   @id @default(uuid())
  role        Role     @unique
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MODELS FROM SCHEMA 2
// ============================================================

model FileObject {
  id           String    @id @default(uuid())
  bucketName   String    @map("bucket_name")
  objectKey    String    @unique @map("object_key")
  originalName String    @map("original_name")
  mimeType     String    @map("mime_type")
  sizeBytes    BigInt    @map("size_bytes")
  extension    String
  checksumMd5  String?   @map("checksum_md5")
  isPublic     Boolean   @default(false) @map("is_public")
  uploadedBy   String    @map("uploaded_by")
  entityType   String?   @map("entity_type")
  entityId     String?   @map("entity_id")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  uploader    User         @relation(fields: [uploadedBy], references: [id])
  hotelImages HotelImage[]
  hotelVideos HotelVideo[]
  roomMedia   RoomMedia[]

  @@index([entityType, entityId])
  @@index([bucketName])
  @@index([uploadedBy])
  @@map("file_objects")
}

model Hotel {
  id                 String             @id @default(uuid())
  ownerId            String             @map("owner_id")
  name               String
  slug               String             @unique
  description        String?
  propertyType       PropertyType       @default(hotel) @map("property_type")
  starRating         Int?               @map("star_rating")
  status             HotelStatus        @default(draft)
  isFeatured         Boolean            @default(false) @map("is_featured")
  totalRooms         Int                @default(0) @map("total_rooms")
  checkInTime        String             @default("14:00") @map("check_in_time")
  checkOutTime       String             @default("12:00") @map("check_out_time")
  minBookingHours    Int?               @map("min_booking_hours")
  cancellationPolicy CancellationPolicy @default(moderate) @map("cancellation_policy")
  cancellationHours  Int                @default(24) @map("cancellation_hours")
  depositPercent     Decimal            @default(0) @map("deposit_percent") @db.Decimal(5, 2)
  avgRating          Decimal            @default(0) @map("avg_rating") @db.Decimal(2, 1)
  totalReviews       Int                @default(0) @map("total_reviews")
  approvedAt         DateTime?          @map("approved_at")
  approvedBy         String?            @map("approved_by")
  rejectionReason    String?            @map("rejection_reason")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  owner          User           @relation("HotelOwner", fields: [ownerId], references: [id])
  approver       User?          @relation("HotelApprover", fields: [approvedBy], references: [id])
  address        HotelAddress?
  images         HotelImage[]
  videos         HotelVideo[]
  roomTypes      RoomType[]
  hotelAmenities HotelAmenity[]

  @@index([ownerId])
  @@index([status])
  @@index([propertyType])
  @@index([avgRating])
  @@index([isFeatured])
  @@map("hotels")
}

model HotelAddress {
  id          String   @id @default(uuid())
  hotelId     String   @unique @map("hotel_id")
  addressLine String   @map("address_line")
  ward        String?
  district    String
  city        String
  province    String
  country     String   @default("Vietnam")
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  fullAddress String?  @map("full_address")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([district])
  @@map("hotel_addresses")
}

model HotelImage {
  id         String   @id @default(uuid())
  hotelId    String   @map("hotel_id")
  fileId     String?  @map("file_id")
  imageUrl   String?  @map("image_url")
  caption    String?
  isCover    Boolean  @default(false) @map("is_cover")
  sortOrder  Int      @default(0) @map("sort_order")
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  hotel    Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  file     FileObject? @relation(fields: [fileId], references: [id])
  uploader User?       @relation(fields: [uploadedBy], references: [id])

  @@map("hotel_images")
}

model HotelVideo {
  id         String   @id @default(uuid())
  hotelId    String   @map("hotel_id")
  fileId     String?  @map("file_id")
  videoUrl   String?  @map("video_url")
  title      String?
  duration   Int?
  sortOrder  Int      @default(0) @map("sort_order")
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  hotel    Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  file     FileObject? @relation(fields: [fileId], references: [id])
  uploader User?       @relation(fields: [uploadedBy], references: [id])

  @@map("hotel_videos")
}

model Amenity {
  id       String          @id @default(uuid())
  name     String          @unique
  slug     String          @unique
  icon     String?
  category AmenityCategory @default(general)
  isActive Boolean         @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")

  hotelAmenities  HotelAmenity[]
  roomTypeAmenities RoomTypeAmenity[]

  @@map("amenities")
}

model HotelAmenity {
  hotelId   String @map("hotel_id")
  amenityId String @map("amenity_id")

  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([hotelId, amenityId])
  @@map("hotel_amenities")
}

model RoomType {
  id          String         @id @default(uuid())
  hotelId     String         @map("hotel_id")
  name        String
  slug        String
  description String?
  maxGuests   Int            @default(2) @map("max_guests")
  bedType     String?        @map("bed_type")
  roomSizeSqm Decimal?       @map("room_size_sqm") @db.Decimal(6, 1)
  totalUnits  Int            @default(1) @map("total_units")
  status      RoomTypeStatus @default(active)
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  hotel             Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomUnits         RoomUnit[]
  media             RoomMedia[]
  pricingPolicies   PricingPolicy[]
  inventory         RoomInventory[]
  roomTypeAmenities RoomTypeAmenity[]

  @@unique([hotelId, slug])
  @@index([hotelId])
  @@index([status])
  @@map("room_types")
}

model RoomUnit {
  id         String         @id @default(uuid())
  roomTypeId String         @map("room_type_id")
  roomNumber String         @map("room_number")
  floor      Int?
  status     RoomUnitStatus @default(available)
  notes      String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, roomNumber])
  @@index([status])
  @@map("room_units")
}

model RoomMedia {
  id         String    @id @default(uuid())
  roomTypeId String    @map("room_type_id")
  fileId     String?   @map("file_id")
  imageUrl   String?   @map("image_url")
  mediaType  MediaType @default(image) @map("media_type")
  caption    String?
  isCover    Boolean   @default(false) @map("is_cover")
  sortOrder  Int       @default(0) @map("sort_order")
  uploadedBy String?   @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  roomType RoomType    @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  file     FileObject? @relation(fields: [fileId], references: [id])
  uploader User?       @relation(fields: [uploadedBy], references: [id])

  @@map("room_media")
}

model RoomTypeAmenity {
  roomTypeId String @map("room_type_id")
  amenityId  String @map("amenity_id")

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([roomTypeId, amenityId])
  @@map("room_type_amenities")
}

model PricingPolicy {
  id                      String      @id @default(uuid())
  roomTypeId              String      @map("room_type_id")
  bookingType             BookingType @map("booking_type")
  basePrice               Decimal     @map("base_price") @db.Decimal(12, 0)
  minHours                Int?        @map("min_hours")
  maxHours                Int?        @map("max_hours")
  extraHourPrice          Decimal?    @map("extra_hour_price") @db.Decimal(12, 0)
  overnightCheckinFrom    String?     @map("overnight_checkin_from")
  overnightCheckoutBefore String?     @map("overnight_checkout_before")
  isActive                Boolean     @default(true) @map("is_active")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  roomType      RoomType       @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  specialPrices SpecialPrice[]

  @@unique([roomTypeId, bookingType])
  @@index([roomTypeId])
  @@map("pricing_policies")
}

model SpecialPrice {
  id              String   @id @default(uuid())
  pricingPolicyId String   @map("pricing_policy_id")
  date            DateTime @db.Date
  price           Decimal  @db.Decimal(12, 0)
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")

  pricingPolicy PricingPolicy @relation(fields: [pricingPolicyId], references: [id], onDelete: Cascade)

  @@unique([pricingPolicyId, date])
  @@map("special_prices")
}

model RoomInventory {
  id          String   @id @default(uuid())
  roomTypeId  String   @map("room_type_id")
  date        DateTime @db.Date
  totalRooms  Int      @map("total_rooms")
  bookedRooms Int      @default(0) @map("booked_rooms")
  isClosed    Boolean  @default(false) @map("is_closed")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
  @@index([date])
  @@map("room_inventory")
}