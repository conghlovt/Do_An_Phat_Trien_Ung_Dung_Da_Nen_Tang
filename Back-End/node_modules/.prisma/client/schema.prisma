generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  partner
  customer
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  username  String
  role      Role     @default(customer)
  code      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
