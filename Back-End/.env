# ==========================================
# SERVER CONFIG
# ==========================================
PORT=5000
HOST=localhost

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# DATABASE CONNECTION
# LƯU Ý: Đã gộp thành 1 DB chung. Bạn có thể đổi tên 'Do_an_da_nen_tang' nếu cần.
# ==========================================
DATABASE_URL="postgresql://postgres:123456@localhost:5432/Do_an_da_nen_tang?schema=public"

# ==========================================
# MINIO OBJECT STORAGE (Dành cho upload file của Partner)
# ==========================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000